{
  "schemaVersion": "1.0.0",
  "toolkitVersion": "0.6.0-draft",
  "extends": "webapp-quality-security",
  "packageType": "route-metadata",
  "rissConcerns": [
    "viewer public buyer journey",
    "wizard setup and publish",
    "dashboard analytics and leads",
    "lead capture",
    "draft preview publish rollback",
    "tenant isolation",
    "Arabic and English UI",
    "mobile buyer journey",
    "public/private payloads",
    "Supabase/RLS if applicable",
    "asset availability",
    "visual/runtime QA"
  ],
  "routes": [
    {
      "id": "riss-critical-flow",
      "purpose": "RISS critical buyer, wizard, dashboard, lead, and publish flow review.",
      "triggerCases": [
        "RISS flow change",
        "publish path",
        "lead capture"
      ],
      "negativeTriggerCases": [
        "docs-only"
      ],
      "requiredScriptsIfAvailable": [
        "typecheck",
        "lint",
        "test",
        "build"
      ],
      "optionalToolsIfAvailable": [
        "playwright",
        "axe-playwright"
      ],
      "approvalRequiredTools": [],
      "stopConditions": [
        "critical flow cannot be validated"
      ],
      "completionReportFields": [
        "flows checked",
        "manual QA",
        "risks"
      ]
    },
    {
      "id": "riss-security-tenant",
      "purpose": "RISS tenant, auth, lead data, and public payload review.",
      "triggerCases": [
        "tenant",
        "auth",
        "lead data",
        "public payload"
      ],
      "negativeTriggerCases": [
        "UI-only"
      ],
      "requiredScriptsIfAvailable": [
        "typecheck",
        "lint",
        "test"
      ],
      "optionalToolsIfAvailable": [
        "gitleaks",
        "osv-scanner",
        "semgrep"
      ],
      "approvalRequiredTools": [
        "socket",
        "trufflehog",
        "owasp-zap-baseline"
      ],
      "stopConditions": [
        "data exposure risk unresolved"
      ],
      "completionReportFields": [
        "security findings",
        "coverage",
        "blockers"
      ]
    },
    {
      "id": "riss-release",
      "purpose": "RISS publish and release readiness gate.",
      "triggerCases": [
        "release",
        "publish",
        "PR"
      ],
      "negativeTriggerCases": [
        "exploration"
      ],
      "requiredScriptsIfAvailable": [
        "typecheck",
        "lint",
        "test",
        "build"
      ],
      "optionalToolsIfAvailable": [
        "github-gh",
        "coderabbit"
      ],
      "approvalRequiredTools": [
        "harden-runner"
      ],
      "stopConditions": [
        "required checks pending"
      ],
      "completionReportFields": [
        "PR status",
        "checks",
        "review",
        "next action"
      ]
    }
  ]
}
